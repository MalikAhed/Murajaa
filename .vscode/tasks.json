{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run local server",
      "type": "shell",
      "command": "python",
      "args": ["-m", "http.server", "8000"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Rebuild content.json",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/build_content_json.py",
        "content_raw/crops",
        "content_raw/answers.md",
        "Math",
        "الوحدة الأولى — تطبيقات هندسية وفيزيائية",
        "أسئلة وزارية وتجريبية (ص ٤٣-٦٦)",
        "content.json"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Install Python deps",
      "type": "shell",
      "command": "pip",
      "args": ["install", "-r", "requirements.txt"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
